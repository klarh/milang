-- Test: import "prelude" gives access to all prelude functions
-- even when names are shadowed at the call site
p = import "prelude"

-- Shadow common prelude names
fold x = x
map x = x
trim x = x

main world =
  -- Access builtins via prelude import
  result1 = p.trim "  hello  "
  result2 = p.fold (\acc x -> acc + x) 0 [1, 2, 3]
  result3 = p.map (\x -> x * 2) [10, 20]
  world.io.println result1
  world.io.println (toString result2)
  world.io.println (toString (p.len result3))
  0

