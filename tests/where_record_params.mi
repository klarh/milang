/* Test: where-clause record bindings with function params */

/* Same-file: record from params in where-clause */
make_pair a b = result
  pair = {x = a; y = b}
  result = pair.x + pair.y

/* Same-file: multiple record bindings */
make_rect x y w h = result
  pos = {x = x; y = y}
  size = {w = w; h = h}
  result = pos.x + pos.y + size.w + size.h

/* Imported module with same patterns */
lib = import "lib/record_builder.mi"

r1 = make_pair 10 20
r2 = lib.make_pair 10 20
r3 = lib.build_and_sum 10 20
r4 = make_rect 1 2 3 4
r5 = lib.make_rect 1 2 3 4

/* 30 + 30 + 30 + 10 + 10 = 110 */
main world = r1 + r2 + r3 + r4 + r5 - 110
