-- Helper module for bug_module_builtin_shadow.mi
-- This module defines its own 'trim' that wraps the prelude's trim.
-- import "prelude" is needed because the module's trim would otherwise
-- shadow the prelude's trim in its own scope (self-recursion).
p = import "prelude"
from str = [str]
_rev xs = fold (\acc x -> concat [x] acc) [] xs
build buf = join "" (_rev buf)
trim buf = from (p.trim (build buf))
