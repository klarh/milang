-- Helper module for bug_module_builtin_shadow.mi
-- Uses import "prelude" to access builtins by qualified name,
-- allowing the module to define its own 'trim' without conflict.
p = import "prelude"
from str = [str]
_rev xs = fold (\acc x -> p.concat [x] acc) [] xs
build buf = join "" (_rev buf)
trim buf = from (p.trim (build buf))
