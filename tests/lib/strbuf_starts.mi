-- Functions that wrap prelude functions of the same name need import "prelude"
-- to avoid self-recursion. Shadow protection handles cross-function references
-- but not same-name wrapping.
p = import "prelude"
_rev xs = fold (\acc x -> concat [x] acc) [] xs
from str = [str]
build buf = join "" (_rev buf)
startsWith buf x = p.startsWith (build buf) x
endsWith buf x = p.endsWith (build buf) x
split buf sep = p.split (build buf) sep
to_words buf = words (build buf)
to_lines buf = lines (build buf)
