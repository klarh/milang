-- BUG: Module-level definitions shadow builtins in imported modules
--
-- When a module defines a function with the same name as a builtin,
-- the builtin becomes inaccessible in the entire module — even in
-- helper functions defined before the shadowing definition.
--
-- Run: milang run tests/bug_module_builtin_shadow.mi
-- Expected: prints "hello"
-- Actual: "match: no matching pattern" (infinite recursion between
--         trim -> bi_trim -> trim -> bi_trim -> ...)
--
-- Root cause: module letrec scoping resolves ALL references to 'trim'
-- (including in bi_trim) to the module's definition, not the builtin.

m = import "bug_shadow_module.mi"

main world =
  result = m.build (m.trim (m.from "  hello  "))
  world.io.println result
