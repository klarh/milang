/* Type inference edge cases — polymorphism, HOF types, recursive types */

/* Polymorphic identity at multiple types */
id :: a : a
id x = x

r1 = id 42
r2 = id "hello"
r3 = id [1, 2, 3]

/* Polymorphic pair operations */
first :: a : b : a
first x y = x

second :: a : b : b
second x y = y

r4 = first 1 "two"
r5 = second "one" 2
r6 = first (first 10 20) 30

/* Higher-order function types */
apply :: (a : b) : a : b
apply f x = f x

compose :: (b : c) : (a : b) : a : c
compose f g x = f (g x)

double x = x * 2
add1 x = x + 1
negate x = 0 - x

r7 = apply double 5
r8 = apply add1 10
r9 = compose double add1 3

/* Polymorphic HOF used at different types */
map_pair :: (a : b) : a : a : {fst = b; snd = b}
map_pair f x y = {fst = f x; snd = f y}

r10 = map_pair double 3 4
r11 = map_pair (\s -> s + "!") "hi" "bye"

/* Type inference through let bindings */
inferred_let = result
  f x = x + 1
  g x = x * 2
  result = f (g 5)

/* Type inference with closures */
make_adder n = f
  f x = x + n
add5 = make_adder 5
r12 = add5 10

/* Recursive function type inference */
sum_list xs = xs -> Nil = 0; Cons h t = h + sum_list t
r13 = sum_list [1, 2, 3, 4, 5]

/* Nested application type inference */
twice :: (a : a) : a : a
twice f x = f (f x)
r14 = twice double 3
r15 = twice add1 0

main world =
  io = world.io
  io.println (toString r1)
  io.println r2
  io.println (toString r4)
  io.println (toString r5)
  io.println (toString r6)
  io.println (toString r7)
  io.println (toString r8)
  io.println (toString r9)
  io.println (toString r10.fst)
  io.println (toString r10.snd)
  io.println r11.fst
  io.println r11.snd
  io.println (toString inferred_let)
  io.println (toString r12)
  io.println (toString r13)
  io.println (toString r14)
  io.println (toString r15)
  0
