-- Test: Module uses import "prelude" to access builtins it shadows.
-- The module defines its own 'trim' that wraps the builtin via p.trim.
--
-- Run: milang run tests/bug_module_builtin_shadow.mi
-- Expected: prints "hello"

m = import "lib/bug_shadow_module.mi"

main world =
  result = m.build (m.trim (m.from "  hello  "))
  world.io.println result
