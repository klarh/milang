-- Test type conversion builtins: float, round, floor, ceil, abs

main world =
  io = world.io
  assert msg expected actual = if (expected == actual) 0 (io.println ("FAIL: " + msg + " expected " + (toString expected) + " got " + (toString actual)))

  -- int to float
  assert "float" 5.0 (float 5)
  assert "float neg" (0.0 - 3.0) (float (0 - 3))

  -- round
  assert "round up" 4 (round 3.7)
  assert "round down" 3 (round 3.2)
  assert "round half" 4 (round 3.5)

  -- floor
  assert "floor pos" 3 (floor 3.9)
  assert "floor neg" (0 - 4) (floor (0.0 - 3.1))

  -- ceil
  assert "ceil pos" 4 (ceil 3.1)
  assert "ceil neg" (0 - 3) (ceil (0.0 - 3.9))

  -- abs
  assert "abs pos" 5 (abs 5)
  assert "abs neg" 5 (abs (0 - 5))
  assert "abs zero" 0 (abs 0)
  assert "abs float" 3.14 (abs (0.0 - 3.14))

  -- neg
  assert "neg" (0 - 5) (neg 5)
  assert "neg neg" 5 (neg (0 - 5))

  -- min / max
  assert "min" 3 (min 3 7)
  assert "max" 7 (max 3 7)
  assert "min eq" 5 (min 5 5)

  io.println "type_conversions: all passed"
  0
