/* Trait system correctness tests */

/* === Fix 1: World aliasing should be detected === */
printer :~ [console]
printer w = w.io.println "aliased"
should_fail :~ []
should_fail world =
  printer world

/* === Fix 7: Rebound println should keep effect tracking === */
rebind_test :~ []
rebind_test world =
  println "hello"

/* === Trait inference: unannotated functions have effects inferred === */
impure_no_annotation world = world.io.println "inferred"

/* Explicitly annotated pure calling unannotated impure should still fail */
bad_caller :~ []
bad_caller world = impure_no_annotation world

main world =
  world.io.println "trait tests"
