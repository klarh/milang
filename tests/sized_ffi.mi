-- Test that FFI correctly handles integer widths and signedness
lib = import' "lib/sized_ffi_test.h" ({src = "lib/sized_ffi_test.c"})

main world =
  pr = world.io.println

  -- Signed addition at various widths
  pr (toString (lib.add_i8 10 20))     -- 30
  pr (toString (lib.add_i16 1000 2000)) -- 3000
  pr (toString (lib.add_i32 100000 200000)) -- 300000
  pr (toString (lib.add_i64 1000000000 2000000000)) -- 3000000000

  -- Unsigned addition
  pr (toString (lib.add_u8 100 155))   -- 255
  pr (toString (lib.add_u16 40000 25535)) -- 65535
  pr (toString (lib.add_u32 3000000000 1294967295)) -- 4294967295
  pr (toString (lib.add_u64 10000000000 20000000000)) -- 30000000000

  -- Overflow behavior (void→value functions need a dummy arg to trigger the call)
  pr (toString (lib.overflow_i8 0))   -- -128 (signed overflow wraps)
  pr (toString (lib.overflow_u8 0))   -- 0 (unsigned overflow wraps)

  -- Max unsigned values
  pr (toString (lib.max_u8 0))   -- 255
  pr (toString (lib.max_u16 0))  -- 65535
  pr (toString (lib.max_u32 0))  -- 4294967295

  -- Float widths
  pr (toString (lib.add_f32 1.5 2.5))  -- 4
  pr (toString (lib.add_f64 1.5 2.5))  -- 4

  -- Mixed width: uint8_t → int32_t
  pr (toString (lib.identity_u8_to_i32 42)) -- 42
