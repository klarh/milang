-- Monad system test: => operator, prelude monad, Maybe monad
-- Tests that monad/maybe from prelude work for short-circuiting

-- Value collector using #block
collect #block = go_collect block.fields
go_collect fields = fields ->
  Nil = Nil
  Cons field rest = Cons ($field.val) (go_collect rest)

safediv a b = if (b == 0) Nothing (Just (a / b))

main world =
  -- Test Maybe monad from prelude (success case)
  r1 = maybe =>
    x = safediv 10 2
    y = safediv x 1
    y
  world.io.println ("maybe ok: " + toString r1)

  -- Test Maybe monad (failure case)
  r2 = maybe =>
    x = safediv 10 0
    y = safediv x 5
    y
  world.io.println ("maybe fail: " + toString r2)

  -- Test custom monad (identity)
  id_m = monad ({bind = \a f -> f a; return = \v -> v})
  r3 = id_m =>
    x = 10
    y = x + 5
    y * 2
  world.io.println ("identity: " + toString r3)

  -- Test value collector with =>
  vals = collect =>
    1 + 2
    3 * 4
    10
  world.io.println ("collect: " + toString vals)

  0
