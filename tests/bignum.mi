-- Test arbitrary-precision integers (Int' 0 / Int)
-- Int = Int' 0 provides arbitrary precision with automatic bignum promotion

-- Compile-time: Haskell partial evaluator handles arbitrary precision
ct_pow = (Int 2) ** 100
ct_fact = (Int 1) * (Int 2) * (Int 3) * (Int 4) * (Int 5) * (Int 6) * (Int 7) * (Int 8) * (Int 9) * (Int 10) * (Int 11) * (Int 12) * (Int 13) * (Int 14) * (Int 15) * (Int 16) * (Int 17) * (Int 18) * (Int 19) * (Int 20)

-- Runtime: C bignum library
rt_double x = (Int x) + (Int x)
rt_square x = (Int x) * (Int x)

main world =
  pr = world.io.println
  -- Compile-time bignums
  pr (toString ct_pow)     -- 1267650600228229401496703205376
  pr (toString ct_fact)    -- 2432902008176640000 (20! fits in one display)

  -- Runtime overflow into bignum
  pr (toString (rt_double 9223372036854775807))  -- 18446744073709551614

  -- Runtime large multiplication
  pr (toString (rt_square 9999999999))  -- 99999999980000000001

  -- Negative bignums
  big = Int' 0 10000000000000000000
  pr (toString (Int' 0 0 - big))  -- -10000000000000000000

  -- Comparison
  a = Int' 0 10000000000000000000
  b = Int' 0 10000000000000000001
  pr (toString (a < b))   -- 1
  pr (toString (a == a))  -- 1
  pr (toString (b > a))   -- 1

  -- Fixed-width ints still clamp
  pr (toString ((Int' 8 100) + (Int' 8 50)))  -- -106

  -- Division
  pr (toString ((Int' 0 100000000000000000000) / (Int' 0 3)))  -- 33333333333333333333
