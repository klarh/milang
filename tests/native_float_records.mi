-- Systematic tests for record pattern matching with float fields
-- Tests record creation, field access, pattern matching with floats

-- Record with float fields
make_point x y = {x = x; y = y}

-- Pattern match on record with float fields
distance_sq p = p.x * p.x + p.y * p.y

-- Pattern match in case with float values
classify_point p = if (distance_sq p > 100.0) "far" (if (distance_sq p > 1.0) "near" "origin")

-- Record update with float
move_point p dx dy = {x = p.x + dx; y = p.y + dy}

-- List of records with float fields processed by fold
sum_distances points = fold (\acc p -> acc + distance_sq p) 0.0 points

-- Nested records with floats
make_line p1 p2 = {start = p1; end_ = p2}
line_length_sq l = distance_sq (make_point (l.end_.x - l.start.x) (l.end_.y - l.start.y))

-- Record with mixed int/float fields
make_particle pos vel mass = {pos = pos; vel = vel; mass = mass; age = 0}
step_particle p dt = ({pos = new_pos; vel = p.vel; mass = p.mass; age = p.age + 1})
  new_pos = make_point (p.pos.x + p.vel.x * dt) (p.pos.y + p.vel.y * dt)

-- Simulate N steps
simulate p dt n = if (n >= 10) p (simulate (step_particle p dt) dt (n + 1))

main world =
  io = world.io
  -- Basic point operations
  p1 = make_point 3.0 4.0
  io.println (toString (distance_sq p1))
  io.println (classify_point p1)
  -- Move point
  p2 = move_point p1 1.0 (0.0 - 1.0)
  io.println (toString p2.x)
  io.println (toString p2.y)
  -- Sum distances
  points = map (\i -> make_point (i * 1.0 + 0.0) (i * 2.0 + 0.0)) (range 1 4)
  io.println (toString (sum_distances points))
  -- Line
  l = make_line (make_point 0.0 0.0) (make_point 3.0 4.0)
  io.println (toString (line_length_sq l))
  -- Particle simulation
  particle = make_particle (make_point 0.0 0.0) (make_point 1.0 0.5) 1.0
  final = simulate particle 0.1 0
  io.println (toString final.pos.x)
  io.println (toString final.pos.y)
  io.println (toString final.age)
